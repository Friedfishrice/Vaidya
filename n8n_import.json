      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ response_text: $json.responseText, risk_level: $json.riskLevel, escalate: $json.escalate, reminder_set: $json.needsReminder || false }) }}",
        "options": {
