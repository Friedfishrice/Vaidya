                    }
                  }
                ],
                "combinator": "and"
              }
            },
            {
              "outputKey": "symptom_triage",
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
