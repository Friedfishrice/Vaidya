          ]
        },
        "options": {}
      },
      "id": "node-patient-rx",
      "name": "Get Patient (Rx)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        900,
        160
      ]
    },
    {
      "parameters": {
        "jsCode": "const prescription = items[0].json.prescriptionRaw || '';\nconst drugMatch = prescription.match(/(\\w+)\\s*(\\d+(?:\\.\\d+)?)\\s*mg/i);\nlet drugName = 'Medicine', doseMg = 0, frequency = '', timingNotes = '';\nif (drugMatch) { drugName = drugMatch[1]; doseMg = parseFloat(drugMatch[2]); }\nif (/subah.*shaam|morning.*evening|twice/i.test(prescription)) { frequency = 'twice daily'; timingNotes = 'subah aur shaam, khane ke baad'; }\nelse if (/subah|morning/i.test(prescription)) { frequency = 'once daily'; timingNotes = 'subah khane ke baad'; }\nelse { frequency = 'once daily'; timingNotes = 'khane ke baad'; }\nreturn [{ json: { ...items[0].json, drugName, doseMg, frequency, timingNotes } }];"
      },
      "id": "node-parse-rx",
      "name": "Parse Prescription",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        160
      ]
    },
    {
      "parameters": {
        "url": "=http://127.0.0.1:8000/collections/guideline_vectors/points/search",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"limit\": 3, \"with_payload\": true, \"filter\": { \"must\": [ { \"key\": \"condition\", \"match\": { \"value\": \"{{ $json.drugName.toLowerCase() }}\" } } ] } }",
        "options": {}
      },
      "id": "node-qdrant-rx",
      "name": "Qdrant Guideline (Rx)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1340,
        160
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = items[0].json;\nconst guideline = (item.result && item.result[0] && item.result[0].payload && item.result[0].payload.text) ? item.result[0].payload.text : 'Dawai doctor ke bataye anusaar lein. Koi bhi problem ho toh turant doctor se milein.';\nconst lang = item.language || 'hi';\nlet msg = '';\nif (lang === 'hi' || lang === 'hindi') { msg = `${item.drugName} ${item.doseMg}mg ki goli ${item.timingNotes} leni hai.\\n${guideline}\\nYaad rakhen: yeh dawai bina doctor ki salaah ke band na karein.`; }\nelse if (lang === 'kn' || lang === 'kannada') { msg = `${item.drugName} ${item.doseMg}mg dose tegeyabeku. ${item.timingNotes}.\\n${guideline}`; }\nelse if (lang === 'ta' || lang === 'tamil') { msg = `${item.drugName} ${item.doseMg}mg ${item.timingNotes} edukkavum.\\n${guideline}`; }\nelse { msg = `Take ${item.drugName} ${item.doseMg}mg ${item.frequency}, ${item.timingNotes}.\\n${guideline}`; }\nreturn [{ json: { responseText: msg, riskLevel: 'low', needsReminder: true, escalate: false, drugName: item.drugName, patientPhone: item.patientPhone, callId: item.callId, language: lang } }];"
      },
      "id": "node-build-rx",
      "name": "Build Rx Explanation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        160
      ]
    },
    {
      "parameters": {
        "url": "=http://127.0.0.1:8000/reminders/schedule",
        "sendBody": true,
        "bodyParameters": {
