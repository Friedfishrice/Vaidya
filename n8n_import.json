    {
      "parameters": {
        "url": "=http://127.0.0.1:8000/collections/guideline_vectors/points/search",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"limit\": 3, \"with_payload\": true, \"filter\": { \"must\": [ { \"key\": \"category\", \"match\": { \"value\": \"symptom_triage\" } }, { \"key\": \"language\", \"match\": { \"value\": \"{{ $json.language }}\" } } ] } }",
        "options": {}
