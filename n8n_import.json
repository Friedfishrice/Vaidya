    {
      "parameters": {
        "url": "=http://127.0.0.1:8000/collections/encounter_vectors/points/search",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"limit\": 2, \"with_payload\": true, \"filter\": { \"must\": [ { \"key\": \"patient_phone\", \"match\": { \"value\": \"{{ $json.patientPhone }}\" } } ] } }",
        "options": {}
      },
      "id": "node-qdrant-history",
      "name": "Qdrant Past Encounters",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1340,
        440
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = items[0].json;\nconst symptoms = (item.symptomsText || '').toLowerCase();\nconst lang = item.language || 'hi';\nconst guidelineText = (item.result && item.result[0] && item.result[0].payload && item.result[0].payload.text) ? item.result[0].payload.text : 'Paani piyen, aaram karein, paracetamol le sakte hain agar allergy na ho.';\nconst redFlags = ['breathlessness', 'chest pain', 'confusion', 'bleeding', 'unconscious', 'seizure', 'nas band', 'sans lena mushkil'];\nconst hasRed = redFlags.some(f => symptoms.includes(f));\nlet risk = 'low';\nif (hasRed) risk = 'high';\nelse if (symptoms.includes('fever') && symptoms.includes('cough')) risk = 'medium';\nconst urgencyHi = risk === 'high' ? 'CHETAVNI: Turant 108 call karein ya najdeeki aspatal jayein.' : risk === 'medium' ? '24 ghante mein agar aaram na mile toh doctor se milein.' : 'Ghar par dekhbhal karte rahein.';\nconst urgencyKn = risk === 'high' ? 'ECCARIKE: Turant 108 call madi ya hospital ge hogi.' : risk === 'medium' ? '24 gante mele sudharaneyagade iddare doctor nodi.' : 'Maneyalli elagadi madi.';\nconst urgencyTa = risk === 'high' ? 'EDARCIKKAI: Udan 108 call seyyungal ya hospital sellungal.' : risk === 'medium' ? '24 manikku ulle sumai kurayavillai endral doctor idam selvungal.' : 'Veetil kadhai pathukaththudan irungal.';\nlet msg = '';\nif (lang === 'hi' || lang === 'hindi') { msg = `Aapke lakshan: ${item.symptomsText}\\nSalah: ${guidelineText}\\n${urgencyHi}`; }\nelse if (lang === 'kn' || lang === 'kannada') { msg = `Nimma lakshanagalu: ${item.symptomsText}\\nSahaaya: ${guidelineText}\\n${urgencyKn}`; }\nelse if (lang === 'ta' || lang === 'tamil') { msg = `Ungal arikauraigal: ${item.symptomsText}\\nUtavi: ${guidelineText}\\n${urgencyTa}`; }\nelse { msg = `Symptoms: ${item.symptomsText}\\nAdvice: ${guidelineText}\\n${risk === 'high' ? 'Seek immediate care.' : risk === 'medium' ? 'See a doctor if no improvement in 24 hours.' : 'Continue home care.'}`; }\nreturn [{ json: { responseText: msg, riskLevel: risk, needsReminder: False, escalate: risk === 'high', patientPhone: item.patientPhone, callId: item.callId, language: lang } }];"
      },
      "id": "node-build-triage",
      "name": "Build Triage Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        440
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { responseText: 'Mujhe is sawaal ka sahi jawab nahi pata. Kripya apne najdeeki doctor ya health center se baat karein.', riskLevel: 'low', needsReminder: false, escalate: false, patientPhone: items[0].json.patientPhone || '', callId: items[0].json.callId || '', language: items[0].json.language || 'hi' } }];"
      },
      "id": "node-default",
      "name": "Default Fallback",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        680
      ]
    },
