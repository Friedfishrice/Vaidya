    {
      "parameters": {
        "rules": {
          "rules": [
            {
              "outputKey": "explain_prescription",
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.intent }}",
                    "rightValue": "explain_prescription",
